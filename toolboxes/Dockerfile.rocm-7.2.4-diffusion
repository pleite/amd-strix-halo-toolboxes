# build stage
FROM registry.fedoraproject.org/fedora:43 AS builder

# rocm 7.2.4 repo
RUN <<'EOF'
tee /etc/yum.repos.d/rocm.repo <<REPO
[ROCm-7.2.4]
name=ROCm7.2.4
baseurl=https://repo.radeon.com/rocm/rhel10/7.2.4/main
enabled=1
priority=50
gpgcheck=1
gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key
REPO
EOF

# deps
RUN dnf -y --nodocs --setopt=install_weak_deps=False \
  --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
  install \
  make gcc cmake lld clang clang-devel compiler-rt libcurl-devel ninja-build \
  rocm-llvm rocm-device-libs hip-runtime-amd hip-devel \
  rocblas rocblas-devel hipblas hipblas-devel rocm-cmake libomp-devel libomp \
  rocminfo radeontop \
  git-core vim sudo rsync patch \
  && dnf clean all && rm -rf /var/cache/dnf/*

# rocm env
ENV ROCM_PATH=/opt/rocm \
  HIP_PATH=/opt/rocm \
  HIP_CLANG_PATH=/opt/rocm/llvm/bin \
  HIP_DEVICE_LIB_PATH=/opt/rocm/amdgcn/bitcode \
  PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH

# llama.cpp (DiffusionGemma PR)
# Builds llama-diffusion-cli from the specific Diffusion Gemma PR:
#   https://github.com/ggml-org/llama.cpp/pull/24423
# This is the "gh pr checkout 24423" step from the Unsloth Gemma Diffusion
# llama.cpp guide, done with plain git (no gh CLI needed) by fetching the
# PR head ref. Override PR/REPO/BRANCH at build time if the PR moves or merges.
WORKDIR /opt/llama.cpp
ARG REPO=https://github.com/ggml-org/llama.cpp.git
ARG BRANCH=master
ARG PR=24423
RUN git clone -b ${BRANCH} --single-branch --recursive ${REPO} . \
  && if [ -n "${PR}" ]; then \
       git fetch origin "pull/${PR}/head:pr-${PR}" \
       && git checkout "pr-${PR}" \
       && git submodule update --init --recursive; \
     fi

COPY llama-grammar.patch /tmp/llama-grammar.patch

# build
# The DiffusionGemma PR adds the llama-diffusion-cli tooling. We build the full
# project (Release) so the toolbox also ships llama-cli / llama-server, then
# install. The grammar patch targets master and is applied best-effort so a
# diverged PR branch does not break the build.
RUN git clean -xdf \
  && git submodule update --recursive \
  && (patch -p1 < /tmp/llama-grammar.patch || echo "grammar patch skipped (does not apply to PR branch)") \
  && cmake -S . -B build \
  -DGGML_HIP=ON \
  -DAMDGPU_TARGETS=gfx1151 \
  -DCMAKE_BUILD_TYPE=Release \
  -DGGML_RPC=ON \
  -DLLAMA_HIP_UMA=ON \
  -DLLAMA_BUILD_EXAMPLES=ON \
  -DGGML_CUDA_ENABLE_UNIFIED_MEMORY=ON \
  -DROCM_PATH=/opt/rocm \
  -DHIP_PATH=/opt/rocm \
  -DHIP_PLATFORM=amd \
  && cmake --build build --config Release -- -j$(nproc) \
  && cmake --install build --config Release

# verify the diffusion CLI was built and installed
RUN test -x /usr/local/bin/llama-diffusion-cli \
  || cp /opt/llama.cpp/build/bin/llama-diffusion-cli /usr/local/bin/llama-diffusion-cli

# libs
RUN mkdir -p /usr/local/lib64 \
  && find /opt/llama.cpp/build -type f -name 'lib*.so*' -exec cp {} /usr/local/lib64/ \; \
  && ldconfig

# helper
COPY gguf-vram-estimator.py /usr/local/bin/gguf-vram-estimator.py
RUN chmod +x /usr/local/bin/gguf-vram-estimator.py

# runtime stage
FROM registry.fedoraproject.org/fedora-minimal:43

# rocm 7.2.4 repo
RUN <<'EOF'
tee /etc/yum.repos.d/rocm.repo <<REPO
[ROCm-7.2.4]
name=ROCm7.2.4
baseurl=https://repo.radeon.com/rocm/rhel10/7.2.4/main
enabled=1
priority=50
gpgcheck=1
gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key
REPO
EOF

# runtime deps
RUN microdnf -y --nodocs --setopt=install_weak_deps=0 \
  --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
  install \
  bash ca-certificates libatomic libstdc++ libgcc libgomp sudo \
  hip-runtime-amd rocblas hipblas \
  rocminfo radeontop procps-ng \
  && microdnf clean all && rm -rf /var/cache/dnf/*

# copy
COPY --from=builder /usr/local/ /usr/local/
COPY --from=builder /opt/llama.cpp/build/bin/rpc-* /usr/local/bin/

# ld
RUN echo "/usr/local/lib"  > /etc/ld.so.conf.d/local.conf \
  && echo "/usr/local/lib64" >> /etc/ld.so.conf.d/local.conf \
  && ldconfig \
  && cp -n /usr/local/lib/libllama*.so* /usr/lib64/ 2>/dev/null || true \
  && cp -n /usr/local/lib64/libllama*.so* /usr/lib64/ 2>/dev/null || true \
  && ldconfig

# helper
COPY gguf-vram-estimator.py /usr/local/bin/gguf-vram-estimator.py
RUN chmod +x /usr/local/bin/gguf-vram-estimator.py

# profile
RUN printf '%s\n' \
  'echo "Diffusion toolbox: run diffusion LLMs (e.g. Unsloth Gemma Diffusion) with llama-diffusion-cli."' \
  > /etc/profile.d/rocm.sh && chmod +x /etc/profile.d/rocm.sh \
  && echo 'source /etc/profile.d/rocm.sh' >> /etc/bashrc

# shell
CMD ["/bin/bash"]
